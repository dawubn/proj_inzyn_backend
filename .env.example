# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
APP_ALLOWED_HOSTS=["*"]

# Database
POSTGRES_USER=docanalyzer
POSTGRES_PASSWORD=docanalyzer
POSTGRES_DB=doc_analyzer
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://docanalyzer:docanalyzer@db:5432/doc_analyzer

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here

# File storage
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=["pdf","jpg","jpeg","png"]
CLASSIFIER_MODEL_PATH=storage/classifier_model.joblib
CLASSIFIER_MIN_CONFIDENCE=0.45

# Logging
LOG_LEVEL=INFO

# Local OCR / Redaction
LOCAL_OCR_LANG=pol+eng
LOCAL_OCR_DPI=300
LOCAL_OCR_MIN_CONFIDENCE=30
REDACTION_BOX_PADDING_PX=8
REDACTION_TIMEOUT_SECONDS=120
